# .env-шаблон для anti-ms-mp
# Скопируй в .env и заполни ОДНО поле — SUPABASE_SERVICE_ROLE_KEY.
# Всё остальное я (Claude) могу заполнить сам, но шаблон оставляю чтобы видел весь набор.
#
# После заполнения я скопирую этот .env на:
#   - VDSina (/opt/anti-ms-mp/.env) — для парсера
#   - Vultr  (/opt/anti-ms-mp-watcher/.env) — для ИИ-watcher и n8n
#
# Файл .env гит-игнорируется.

# === Supabase ===
SUPABASE_URL=https://yqfdbuiyfkzhkhpiknob.supabase.co
SUPABASE_ANON_KEY=sb_publishable_nZNZLCqx4e_7La8pfQmsjA_RSw0zT9t

# 👇 ЗАПОЛНИ ЭТО ПОЛЕ (Dashboard → Project Settings → API Keys → service_role → Reveal):
SUPABASE_SERVICE_ROLE_KEY=

# === Парсер на VDSina ===
SCRAPER_PROXY=
# Пусто = напрямую с VDSina (там RU-IP).
# Если запускаешь парсер с другого VPS — поставь socks5://127.0.0.1:1080
# и подними туннель к VDSina командой:
#   ssh -fNT -D 127.0.0.1:1080 -i ~/.ssh/VDSina root@94.103.89.251

# === Уведомления через n8n на Vultr ===
